# Copy this file to server/.env and fill in the values

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/weaxle78

# Bun API server port (default: 3001)
API_PORT=3001

# Allowed CORS origin (default: http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Twitch API
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_LOGIN=
